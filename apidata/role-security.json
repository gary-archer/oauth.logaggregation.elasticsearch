{
  "description": "Read access to audit logs",
  "indices": [
    {
      "names": ["apiauditlogs", "api-audit-*"],
      "privileges": ["read"]
    }
  ],
  "applications": [
    {
      "application":"kibana-.kibana",
      "privileges": ["space_all"],
      "resources":["space:default"]
    }
  ]
}
